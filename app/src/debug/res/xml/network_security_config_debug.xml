<!-- #63: DEBUG builds only. Cleartext HTTP is permitted ONLY to the local dev
     server (the emulator host 10.0.2.2, and localhost/127.0.0.1) so a debug
     build can pair against the docker harness out of the box. Everything else
     stays HTTPS-only, and release builds don't ship this at all. -->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
    </domain-config>
</network-security-config>
